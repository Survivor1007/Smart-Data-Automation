

# .env.example

# Database Configuration (used by both local and Docker)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/smartdata

# For local development (without Docker), use this instead:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/smartdata

# FastAPI Settings
APP_NAME=Smart Data Automation Platform
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Optional: Secret key for future JWT/auth
# SECRET_KEY=your-super-secret-key-here